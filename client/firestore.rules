rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /rooms/{roomId} {
      // Production rules: restricting access to authenticated users and participants
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.players.creator || 
        request.auth.uid == resource.data.players.joiner ||
        resource.data.players.joiner == null
      );
      allow delete: if request.auth != null && request.auth.uid == resource.data.players.creator;
    }
  }
}
