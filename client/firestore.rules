rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /rooms/{roomId} {
      // MVP rule: any authenticated player can read/write room docs.
      // Tighten this before production by restricting writes to room participants
      // and validating move/turn transitions server-side.
      allow read, write: if request.auth != null;
    }
  }
}
